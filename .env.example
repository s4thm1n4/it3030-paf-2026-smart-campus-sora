# ══════════════════════════════════════════════════
#  Smart Campus Operations Hub — Docker Secrets
#  Group SORA | IT3030 PAF 2026
#
#  SETUP: Copy this file to .env and fill in values
#  $ cp .env.example .env
# ══════════════════════════════════════════════════

# PostgreSQL
POSTGRES_DB=smart_campus_db
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres

# Google OAuth — get from Google Cloud Console
# https://console.cloud.google.com/apis/credentials
GOOGLE_CLIENT_ID=your-google-client-id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your-google-client-secret

# JWT — use a long random string (min 32 chars)
JWT_SECRET=your-super-secret-jwt-key-change-this
JWT_EXPIRATION_MS=86400000

# CORS — comma-separated allowed origins
CORS_ALLOWED_ORIGINS=http://localhost:5173,http://localhost:80,http://localhost

